cat > .gitignore << 'EOF'
# Dados sensíveis da empresa (NUNCA commitar!)
src/data/
*.env
.env.*
*.local
config/api.js
config/keys.js

# Dependências
node_modules/
.pnp/
.pnp.js

# Build
dist/
build/
.next/
out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Sistema
.DS_Store
Thumbs.db

# Relatórios gerados
*.xlsx
*.pdf
EOF